---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="关于" description="关于 FringCat 博客">
	<h1 class="page-title">关于</h1>
	<div class="about-content prose">
		<p>
			这里是 FringCat 的个人博客，用来记录日常、技术笔记和一些随想。
			页面刻意保持简单——留白、衬线字体、柔和色调，让阅读本身成为一件自然的事。
		</p>
		<p>
			你可以在 GitHub 上找到这个站点的
			<a href="https://github.com/FringCat/FringCat.github.io" target="_blank" rel="noopener noreferrer">
				源代码
			</a>
			。
		</p>
	</div>
</BaseLayout>
